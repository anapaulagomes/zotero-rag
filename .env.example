# Optional: override Zotero paths (defaults to ~/Zotero/zotero.sqlite and ~/Zotero/storage)
# ZOTERO_DB=/path/to/zotero.sqlite
# ZOTERO_STORAGE=/path/to/storage

LANCEDB_PATH=./data/lancedb
OLLAMA_HOST=http://localhost:11434

# Retrieval embeddings. EMBED_PROVIDER: ollama | openai (openai also covers any
# OpenAI-compatible endpoint via EMBED_BASE_URL — a local MLX/LM Studio server,
# text-embedding-3, etc.). EMBED_DIM must match the model's real output dimension
# (nomic-embed-text=768, bge-m3=1024). Changing the model requires a full re-ingest.
EMBED_PROVIDER=ollama
EMBED_MODEL=nomic-embed-text
EMBED_DIM=768
# EMBED_BASE_URL=http://localhost:8080/v1

# Answer-layer LLM (independent from the EMBED_* vars used for retrieval).
# LLM_PROVIDER: ollama | claude | openai
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b-instruct

# How many chunks to retrieve. Larger values exploit bigger cloud context windows.
TOP_K=15

# Drop retrieved chunks scoring below this (normalized: 1/(1+distance), higher = closer).
# 0.0 keeps every hit; raise it once you've measured the score distribution on your library.
SCORE_THRESHOLD=0.0

# Required when LLM_PROVIDER=claude (e.g. LLM_MODEL=claude-3-5-sonnet-latest)
# ANTHROPIC_API_KEY=sk-ant-xxx

# Required when LLM_PROVIDER=openai. OPENAI_BASE_URL is optional, for
# OpenAI-compatible endpoints (e.g. other cloud providers).
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://...

# Optional: Hugging Face token. Without it docling falls back to unauthenticated
# downloads (lower rate limit + occasional throttling on first ingestion run).
# HF_TOKEN=hf_xxx
